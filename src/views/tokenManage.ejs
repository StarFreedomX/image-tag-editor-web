<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>语录管理</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #1a1a2e;
            color: #e0e0e0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            min-height: 100vh;
            padding: 40px 20px;
        }
        .container {
            max-width: 640px;
            margin: 0 auto;
            background: #16213e;
            border-radius: 12px;
            padding: 32px;
            box-shadow: 0 4px 24px rgba(0,0,0,.3);
        }
        h1 {
            font-size: 22px;
            color: #fff;
            margin-bottom: 20px;
        }
        .user-info {
            background: #0f3460;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 24px;
        }
        .user-info .row {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            margin-bottom: 4px;
        }
        .user-info .label { color: #888; min-width: 50px; }
        .user-info .value { color: #fff; }
        .user-info .token-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .user-info .token-text {
            font-family: monospace;
            font-size: 13px;
            color: #e94560;
            word-break: break-all;
        }
        .copy-btn {
            padding: 4px 10px;
            font-size: 12px;
            border: 1px solid #555;
            border-radius: 4px;
            background: transparent;
            color: #aaa;
            cursor: pointer;
            white-space: nowrap;
        }
        .copy-btn:hover { border-color: #e94560; color: #e94560; }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 24px;
        }
        th {
            text-align: left;
            font-size: 13px;
            color: #888;
            padding: 10px 0;
            border-bottom: 1px solid #333;
        }
        td {
            padding: 12px 0;
            border-bottom: 1px solid #222;
            font-size: 14px;
        }
        td a {
            color: #e94560;
            text-decoration: none;
        }
        td a:hover { text-decoration: underline; }
        .empty { color: #666; text-align: center; padding: 30px 0; font-size: 14px; }

        .add-form {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
        }
        .add-form input {
            flex: 1;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid #333;
            background: #0f3460;
            color: #fff;
            font-size: 14px;
            outline: none;
        }
        .add-form input:focus { border-color: #e94560; }
        .add-form button {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            background: #e94560;
            color: #fff;
            font-size: 14px;
            cursor: pointer;
            white-space: nowrap;
        }
        .add-form button:hover { background: #d63851; }
        .add-form button:disabled { background: #555; cursor: not-allowed; }

        .msg { font-size: 13px; margin-bottom: 12px; padding: 8px; border-radius: 6px; }
        .msg.error { background: rgba(233,69,96,.15); color: #e94560; }
        .msg.success { background: rgba(46,204,113,.15); color: #2ecc71; }

        .revoke-btn {
            padding: 10px 20px;
            border: 1px solid #e94560;
            border-radius: 8px;
            background: transparent;
            color: #e94560;
            font-size: 14px;
            cursor: pointer;
        }
        .revoke-btn:hover { background: rgba(233,69,96,.1); }

        .bottom-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,.6); z-index: 100;
            display: flex; align-items: center; justify-content: center;
        }
        .modal-box {
            background: #16213e; border-radius: 12px; padding: 28px;
            max-width: 360px; width: 90%; text-align: center;
        }
        .modal-box p { font-size: 15px; margin-bottom: 20px; color: #ccc; }
        .modal-btns { display: flex; gap: 12px; }
        .modal-btns button {
            flex: 1; padding: 10px; border-radius: 8px; font-size: 14px;
            border: none; cursor: pointer;
        }
        .btn-cancel { background: #333; color: #aaa; }
        .btn-cancel:hover { background: #444; }
        .btn-confirm { background: #e94560; color: #fff; }
        .btn-confirm:hover { background: #d63851; }
        #back-button {
            position: fixed; top: 20px; left: 20px; font-size: 24px;
            text-decoration: none; background: #222; color: #eee;
            padding: 6px 12px; border-radius: 8px;
            box-shadow: 0 0 5px rgba(0,0,0,.4); z-index: 1000;
            transition: background .2s;
        }
        #back-button:hover { background: #333; }
    </style>
</head>
<body>
<div class="container">
    <a href="javascript:history.back()" id="back-button" title="返回">←</a>
    <h1>语录管理面板</h1>

    <% if (error) { %>
        <div class="msg error"><%= error %></div>
        <div style="text-align:center;margin-top:20px">
            <a href="/get-token" style="color:#e94560">返回获取 Token</a>
        </div>
    <% } else if (entry) { %>
        <div class="user-info">
            <div class="row">
                <span class="label">用户</span>
                <span class="value"><%= entry.username %></span>
            </div>
            <div class="row">
                <span class="label">Token</span>
                <span class="token-row">
                    <span class="token-text" id="tokenText"><%= entry.token.substring(0, 6) %><%= '*'.repeat(Math.max(0, entry.token.length - 6)) %></span>
                    <button class="copy-btn" onclick="copyToken('<%= entry.token %>')">复制</button>
                </span>
            </div>
            <div class="row">
                <span class="label">平台</span>
                <span class="value"><%= entry.platform %></span>
            </div>
        </div>

        <div id="msgBox"></div>

        <table>
            <thead>
                <tr>
                    <th>群号</th>
                    <th>群名</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% if (groups && groups.length > 0) { %>
                    <% groups.forEach(function(g) { %>
                    <tr>
                        <td><code style="color:#aaa"><%= g.gid %></code></td>
                        <td><%= g.name %></td>
                        <td><a href="/groups/<%= g.folder %>" onclick="document.cookie='starfx_token=<%= entry.token %>;path=/;max-age=3600'">管理</a></td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="3" class="empty">暂无群，请添加</td></tr>
                <% } %>
            </tbody>
        </table>

        <div class="add-form">
            <form id="addGroupForm" style="display:flex;gap:8px;width:100%">
                <input id="groupInput" type="text" placeholder="输入群号（纯数字）" autocomplete="off" style="flex:1">
                <button id="addBtn" type="submit">添加群</button>
            </form>
        </div>

        <div class="bottom-row">
            <% if (entry.role === 'owner') { %>
            <a href="/users" style="color:#80cbc4;font-size:13px;text-decoration:none;margin-right:16px">用户管理</a>
            <a href="/logs" style="color:#80cbc4;font-size:13px;text-decoration:none">操作日志</a>
            <% } else { %><span></span><% } %>
            <button class="revoke-btn" onclick="revokeToken()">退出登录</button>
        </div>
    <% } %>
</div>

<!-- 退出确认弹窗 -->
<div id="logoutModal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <p>确定退出登录？</p>
        <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#888;margin-bottom:20px;cursor:pointer">
            <input type="checkbox" id="deleteTokenCheck" style="width:auto">
            同时删除该 Token（需要重新验证才能恢复）
        </label>
        <div class="modal-btns">
            <button class="btn-cancel" onclick="closeLogoutModal()">取消</button>
            <button class="btn-confirm" onclick="confirmLogout()">确定退出</button>
        </div>
    </div>
</div>

<script>
    <% if (entry) { %>
    const token = '<%= entry.token %>';

    function showMsg(text, type) {
        const box = document.getElementById('msgBox');
        box.innerHTML = '<div class="msg ' + type + '">' + text + '</div>';
        setTimeout(() => box.innerHTML = '', 4000);
    }

    document.getElementById('addGroupForm').addEventListener('submit', (e) => {
        e.preventDefault();
        addGroup();
    });

    async function addGroup() {
        const input = document.getElementById('groupInput');
        const groupId = input.value.trim();
        if (!groupId) { showMsg('请输入群号', 'error'); return; }
        if (!/^\d+$/.test(groupId)) { showMsg('群号应为纯数字', 'error'); return; }

        const btn = document.getElementById('addBtn');
        btn.disabled = true;
        btn.textContent = '验证中...';

        try {
            const resp = await fetch('/manage/add-group', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token, groupId })
            });
            const data = await resp.json();
            if (data.success) {
                showMsg(data.groupId + ' - ' + data.groupName + ' 已添加', 'success');
                input.value = '';
                setTimeout(() => location.reload(), 1500);
            } else {
                showMsg(data.message || '添加失败', 'error');
            }
        } catch {
            showMsg('网络错误', 'error');
        }
        btn.disabled = false;
        btn.textContent = '添加群';
    }

    async function revokeToken() {
        document.getElementById('logoutModal').style.display = '';
    }

    function closeLogoutModal() {
        document.getElementById('logoutModal').style.display = 'none';
    }

    async function confirmLogout() {
        closeLogoutModal();
        if (document.getElementById('deleteTokenCheck').checked) {
            try {
                await fetch('/manage/revoke', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token })
                });
            } catch {}
        }
        document.cookie = 'starfx_token=;path=/;max-age=0';
        window.location.href = '/';
    }

    function copyToken(text) {
        if (navigator.clipboard) {
            navigator.clipboard.writeText(text);
        }
        const btn = event.target;
        const orig = btn.textContent;
        btn.textContent = '已复制';
        setTimeout(() => btn.textContent = orig, 1500);
    }
    <% } else { %>
    // cookie 无效或过期，清理后跳登录页
    document.cookie = 'starfx_token=;path=/;max-age=0';
    window.location.href = '/';
    <% } %>
</script>
</body>
</html>
